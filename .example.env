
# Interswitch
INTERSWITCH_AUTH_URL=
INTERSWITCH_CLIENT_ID=
INTERSWITCH_SECRET_KEY=

# Optional: override OAuth scope used for token minting (default: "profile")
INTERSWITCH_AUTH_SCOPE=

# Optional: some APIs require a resource id/audience included in the token request
INTERSWITCH_AUTH_RESOURCE_ID=

# Optional: BVN can use a different auth URL/scope from invoices
INTERSWITCH_BVN_AUTH_URL=
INTERSWITCH_BVN_SCOPE=
INTERSWITCH_BVN_CLIENT_ID=
INTERSWITCH_BVN_SECRET_KEY=

# Optional: Invoice APIs may require a different auth URL/scope that includes your merchant resource id
# Example (depends on your Interswitch setup): INTERSWITCH_INVOICE_SCOPE="profile project-x-merchant"
INTERSWITCH_INVOICE_AUTH_URL=
INTERSWITCH_INVOICE_SCOPE=
INTERSWITCH_INVOICE_RESOURCE_ID=
INTERSWITCH_INVOICE_CLIENT_ID=
INTERSWITCH_INVOICE_SECRET_KEY=

INTERSWITCH_BVN_URL=
INTERSWITCH_BASE_URL=

NEXT_PUBLIC_ISW_MERCHANT_CODE=
NEXT_PUBLIC_ISW_PAY_ITEM_ID=
NEXT_PUBLIC_ISW_MODE=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
